NEXT_PUBLIC_DEFAULT_CLASS_CODE=AI2026
TEACHER_PASSWORD=teacher-demo-2026

# Preferred production path: Supabase Dashboard > Project Settings > Database
# Use the Session Pooler connection string, not the browser anon key.
SUPABASE_SESSION_POOL_URL=postgresql://postgres.your-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres
POSTGRES_POOL_MAX=5

# Optional local fallback. If no Postgres URL is set, the app runs with in-memory demo storage.
# DATABASE_URL=
# POSTGRES_URL=
